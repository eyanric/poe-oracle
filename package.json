{
  "name": "poe-oracle",
  "version": "0.1.0",
  "description": "PoE 1 AI copilot — read-only, ToS-clean economy & build-analysis MCP server.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Eric Yan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eyanric/poe-oracle.git"
  },
  "bin": {
    "poe-oracle": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "validate:repoe": "node scripts/validate-repoe.mjs",
    "validate:ev": "tsx scripts/ev-sanity.mjs",
    "validate:craft": "tsx scripts/validate-craft.mjs",
    "validate:bench": "tsx scripts/validate-bench-meta.mjs",
    "validate:harvest": "tsx scripts/validate-harvest.mjs",
    "validate:recombine": "tsx scripts/validate-recombine.mjs",
    "validate:eldritch": "tsx scripts/validate-eldritch.mjs",
    "validate:influence": "tsx scripts/validate-influence.mjs",
    "validate:catalysts": "tsx scripts/validate-catalysts.mjs",
    "validate:anoint": "tsx scripts/validate-anoint.mjs",
    "validate:veiled": "tsx scripts/validate-veiled.mjs",
    "nnn:ladder": "tsx scripts/nnn-ladder.mjs",
    "smoke:rare": "tsx scripts/smoke-rare-pricing.mjs",
    "smoke:pob": "tsx scripts/smoke-pob.mjs",
    "make:pob-fixtures": "node scripts/make-pob-fixtures.mjs",
    "dryrun:league": "tsx scripts/dryrun-league-start-3.28.mjs",
    "check": "npm run typecheck && npm run lint && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^20.11.16",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.10.0",
    "vitest": "^2.1.0"
  }
}
